{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ES2022",
        "jsx": "react",
        "strict": true,
        "esModuleInterop": true,
        "lib": ["ES2022"],
        "noImplicitAny": false,
        "noEmitOnError": true,
        "allowSyntheticDefaultImports": true,
        "types": ["@citizenfx/server", "@types/node"],
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "paths": {
            "*": ["./*"]
        }
    },
    "include": [
      "./src/**/*.ts"
    ],
    "exclude": ["**/__tests__/*", "./ui/**/*"]
}
